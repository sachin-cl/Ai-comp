# --- Core ---
ENVIRONMENT=development
SECRET_KEY=change-me-to-a-long-random-string
LOG_LEVEL=INFO

# --- Database ---
DATABASE_URL=postgresql+asyncpg://aicompany:aicompany@postgres:5432/aicompany

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Standalone dev mode (no Docker / Postgres / Redis) ---
# Run everything in one process: SQLite + in-memory queue/pub-sub + mock LLM.
# Single API process only; use real Postgres/Redis for anything multi-replica.
#   DATABASE_URL=sqlite+aiosqlite:///./dev.db
#   REDIS_URL=memory://

# --- LLM providers (set at least one; leave all empty to use the built-in mock provider) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Default provider/model for agents whose YAML doesn't pin one.
# One of: openai | anthropic | gemini | ollama | mock
DEFAULT_LLM_PROVIDER=mock
DEFAULT_LLM_MODEL=mock-small

# Embeddings: openai (text-embedding-3-small) or hash (offline deterministic fallback)
EMBEDDING_PROVIDER=hash

# --- Budgets & safety ---
DEFAULT_TOKEN_BUDGET=2000000
MAX_REVISION_LOOPS=3
MAX_TASK_RETRIES=2
WORKFLOW_TIMEOUT_MINUTES=60
LLM_TIMEOUT_SECONDS=120

# --- Auth ---
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
